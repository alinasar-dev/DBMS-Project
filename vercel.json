{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/login.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/student.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/staff.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/admin.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "public/app.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/styles.css",
      "dest": "public/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "public/app.js"
    },
    {
      "src": "/login",
      "dest": "public/login.html"
    },
    {
      "src": "/student",
      "dest": "public/student.html"
    },
    {
      "src": "/staff",
      "dest": "public/staff.html"
    },
    {
      "src": "/admin",
      "dest": "public/admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ]
}
