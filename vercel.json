{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "login.html",
      "use": "@vercel/static"
    },
    {
      "src": "student.html",
      "use": "@vercel/static"
    },
    {
      "src": "staff.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/styles.css",
      "dest": "styles.css"
    },
    {
      "src": "/app.js",
      "dest": "app.js"
    },
    {
      "src": "/login",
      "dest": "login.html"
    },
    {
      "src": "/student",
      "dest": "student.html"
    },
    {
      "src": "/staff",
      "dest": "staff.html"
    },
    {
      "src": "/admin",
      "dest": "admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
